<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <%= render @food_place %>

    <%= link_to "Edit this food_place", edit_food_place_path(@food_place), class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <div class="inline-block ml-2">
      <%= button_to "Destroy this food_place", food_place_path(@food_place), method: :delete, class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
    </div>
    <%= link_to "Back to food_places", food_places_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  </div>
</div>
