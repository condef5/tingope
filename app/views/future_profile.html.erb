<p class="text-base">Signed as <%= Current.user.email %></p>

<h2 class="text-2xl font-bold mb-4">Login and verification</h2>

<div class="mb-2">
  <%= link_to "Change password", edit_password_path, class: "text-blue-500 hover:underline" %>
</div>

<div class="mb-2">
  <%= link_to "Change email address", edit_identity_email_path, class: "text-blue-500 hover:underline" %>
</div>

<h2 class="text-2xl font-bold mb-4">Access history</h2>

<div class="mb-2">
  <%= link_to "Devices & Sessions", sessions_path, class: "text-blue-500 hover:underline" %>
</div>

<br>

<%= button_to "Log out", Current.session, method: :delete, class: "bg-red-500 text-white px-4 py-2 rounded-full hover:bg-red-700 focus:outline-none focus:shadow-outline-red active:bg-red-800" %>
