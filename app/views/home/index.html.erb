<div class="max-w-[1000px] m-auto">
  <header class="text-center">
    <h1 class="text-3xl font-bold text-balance">Explora los Sabores Diarios de Tingo María</h1>
    <p class="mt-2 text-balance">Descubre la oferta culinaria en diversos lugares, con platos deliciosos, postres irresistibles y mucho más.</p>
  </header>

  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 mt-8 gap-6">
    <% @food_places.each do |food_place| %>
      <div class="card border border-slate-100 w-full bg-base-100 shadow-xl p-5 flex flex-col">
        <h2 class="text-slate-700 text-xl mb-2">
          <%= food_place.name  %>
        </h2>

        <p class="text-sm text-balance">
          <%= food_place.description %>
        </p>

        <div class="flex gap-1 items-center mt-2">
          <svg
            viewBox="0 0 24 24"
            width="20"
            height="16"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <span class="text-sm">
            <%= food_place.address %>
          </span>
        </div>

        <% if food_place.opening_hours.present?  %>
          <div class="flex gap-1 items-center mt-2">
            <svg
            viewBox="0 0 24 24"
            width="20"
            height="16"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <span class="text-sm">
              <%= food_place.opening_hours %>
            </span>
          </div>
        <% end %>

        <div class="pt-2 mt-auto text-sm text-indigo-600">
          <a
            href="<%= food_place.whatsapp_link %>"
            target="_blank"
            aria-label="Pedir por wp a <%= food_place.name %>"
            >
            Pedir por WhatsApp
          </a>
        </div>
      </div>
    <% end  %>
  </div>
</div>

<div class="fixed right-0 sm:left-0 sm:w-full bottom-4 text-white flex justify-end sm:justify-center gap-12 p-2">
  <div class="bg-indigo-500 rounded-full p-4 z-10" title="new food place">
    <%= link_to new_food_place_path, "aria-label": "Nuevo lugar de comida" do %>
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="css-i6dzq1"
      >
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>

    <% end %>
  </div>

  <div class="bg-green-500 rounded-full p-4 z-10" title="new tourist place">
    <%= link_to new_tourist_place_path, "aria-label": "Nuevo lugar de comida" do %>
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="css-i6dzq1"
      >
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>

    <% end %>
  </div>
</div>
